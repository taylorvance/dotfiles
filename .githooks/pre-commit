#!/usr/bin/env bash
# Syntax-check modified shell files before committing.

failed=0

while IFS= read -r file; do
    [[ -f "$file" ]] || continue
    case "$file" in
        *.zsh|*.zshrc)
            if ! zsh -n "$file" 2>&1; then
                echo "zsh syntax error: $file"
                failed=1
            fi
            ;;
        *.sh|*.bash)
            if ! bash -n "$file" 2>&1; then
                echo "bash syntax error: $file"
                failed=1
            fi
            ;;
    esac
done < <(git diff --cached --name-only)

exit $failed
