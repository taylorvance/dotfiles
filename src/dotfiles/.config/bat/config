# bat configuration
# See: bat --help

# Set theme (installed by src/install-tools.sh when bat is available)
--theme="tokyonight_moon"

# Show line numbers and git modifications
--style="numbers,changes"

# Use italic text (if terminal supports it)
--italic-text=always

# Map file extensions
--map-syntax "*.conf:INI"
--map-syntax ".ignore:Git Ignore"
