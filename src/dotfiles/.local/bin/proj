#!/bin/bash
# proj - tmux session manager
#
# Manage tmux sessions with intuitive create/attach/kill operations.

set -e

show_help() {
	cat <<EOF
Usage: proj [OPTIONS] [NAME]

Tmux session manager.

USAGE:
    proj                 fzf picker of existing sessions → attach
    proj NAME            attach to session by name (fzf on multiple matches,
                         prompt to create if none found)
    proj -c [NAME]       create session from cwd (name defaults to basename \$PWD)
    proj -k [NAME]       kill session (current session if in tmux, else fzf picker)

OPTIONS:
    -c, --create [NAME]  Create session from cwd
    -k, --kill [NAME]    Kill a session
    -h, --help           Show this help message

EXAMPLES:
    proj                 Pick from existing sessions
    proj dotfiles        Attach to "dotfiles" session
    proj dot             Attach if unambiguous, fzf if multiple matches,
                         prompt to create if none
    proj -c              Create session named after current directory
    proj -c myapp        Create session named "myapp" from current directory
    proj -k              Kill current session (or fzf pick if not in tmux)
    proj -k dotfiles     Kill "dotfiles" session

EOF
}

die() {
	echo "Error: $1" >&2
	exit 1
}

in_tmux() {
	[ -n "$TMUX" ]
}

session_exists() {
	tmux has-session -t="$1" 2>/dev/null
}

list_sessions() {
	tmux list-sessions -F '#{session_name}' 2>/dev/null
}

attach_session() {
	local name="$1"
	if in_tmux; then
		tmux switch-client -t "$name"
	else
		tmux attach-session -t "$name"
	fi
}

do_create() {
	local name="$1"
	[ -z "$name" ] && name=$(basename "$PWD" | tr '. ' '__')

	if session_exists "$name"; then
		die "Session '$name' already exists"
	fi

	if in_tmux; then
		tmux new-session -d -s "$name" -c "$PWD"
		tmux switch-client -t "$name"
	else
		tmux new-session -s "$name" -c "$PWD"
	fi
}

do_kill() {
	local name="$1"

	if [ -n "$name" ]; then
		session_exists "$name" || die "Session '$name' does not exist"
	elif in_tmux; then
		name=$(tmux display-message -p '#{session_name}')
	else
		if ! command -v fzf >/dev/null 2>&1; then
			die "Specify a session name or install fzf for interactive selection"
		fi
		local sessions
		sessions=$(list_sessions) || die "No tmux sessions running"
		[ -z "$sessions" ] && die "No tmux sessions running"
		name=$(echo "$sessions" | fzf --height=40% --reverse --prompt="Kill session: ") || exit 0
		[ -z "$name" ] && exit 0
	fi

	tmux kill-session -t "$name"
	echo "Killed session: $name"
}

find_matching_sessions() {
	local query="$1"
	local sessions
	sessions=$(list_sessions 2>/dev/null) || return 0
	[ -z "$sessions" ] && return 0

	# Exact match first
	if echo "$sessions" | grep -qx "$query"; then
		echo "$query"
		return 0
	fi

	# Substring match
	echo "$sessions" | grep -i "$query" || true
}

do_attach() {
	local name="$1"

	# No name: fzf picker over all sessions
	if [ -z "$name" ]; then
		if ! command -v fzf >/dev/null 2>&1; then
			die "Specify a session name or install fzf for interactive selection"
		fi
		local sessions
		sessions=$(list_sessions) || die "No tmux sessions running"
		[ -z "$sessions" ] && die "No tmux sessions running"
		local selected
		selected=$(echo "$sessions" | fzf --height=40% --reverse --prompt="Attach to session: ") || exit 0
		[ -z "$selected" ] && exit 0
		attach_session "$selected"
		return
	fi

	# Name given: find matches
	local matches
	matches=$(find_matching_sessions "$name")

	local count=0
	[ -n "$matches" ] && count=$(echo "$matches" | grep -c .)

	if [ "$count" -eq 1 ]; then
		attach_session "$matches"
	elif [ "$count" -gt 1 ]; then
		if ! command -v fzf >/dev/null 2>&1; then
			die "Multiple sessions match '$name': $(echo "$matches" | tr '\n' ' ')"
		fi
		local selected
		selected=$(echo "$matches" | fzf --height=40% --reverse --prompt="Multiple matches, select: ") || exit 0
		[ -z "$selected" ] && exit 0
		attach_session "$selected"
	else
		# No matches: prompt to create
		printf "No session '%s'. Create one here? (cwd: %s) [y/N] " "$name" "$PWD"
		read -r response
		case "$response" in
			[yY]) do_create "$name" ;;
			*) exit 0 ;;
		esac
	fi
}

main() {
	local create_mode=false
	local kill_mode=false
	local name=""

	while [ $# -gt 0 ]; do
		case "$1" in
			-h|--help)
				show_help
				exit 0
				;;
			-c|--create)
				create_mode=true
				shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
					name="$1"
					shift
				fi
				;;
			-k|--kill)
				kill_mode=true
				shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
					name="$1"
					shift
				fi
				;;
			-*)
				die "Unknown option: $1"
				;;
			*)
				name="$1"
				shift
				;;
		esac
	done

	if ! command -v tmux >/dev/null 2>&1; then
		die "tmux is not installed"
	fi

	if [ "$create_mode" = true ]; then
		do_create "$name"
	elif [ "$kill_mode" = true ]; then
		do_kill "$name"
	else
		do_attach "$name"
	fi
}

main "$@"
