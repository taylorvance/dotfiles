[user]
	name = Taylor Vance

[alias]
	st = status
	di = diff
	a = add .
	c = commit
	cm = commit -m
	s = switch
	f = fetch
	p = pull
	g = grep --break --heading --line-number
	l = log --graph --oneline --decorate
	ll = log --graph --pretty='%C(auto)%h%d %s %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset' --abbrev-commit
	cfg = config --list
	amend = commit --amend --no-edit
	smp = "!git switch main && git pull --ff-only"
	fmom = "!git fetch && git merge origin/main"
	from = "!git fetch && git rebase origin/main"

[diff]
	tool = nvimdiff
	colorMoved = default
[merge]
	tool = nvimdiff
[mergetool]
	keepBackup = false

[pager]
	diff = delta
	log = delta
	reflog = delta
	show = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	line-numbers = true
	syntax-theme = tokyonight_moon
	file-decoration-style = magenta box
	hunk-header-decoration-style = cyan box

[core]
	editor = nvim
	excludesFile = ~/.gitignore
	pager = delta

[grep]
	extendRegexp = true
	lineNumber = true

[credential]
	helper = osxkeychain

[include]
	path = ~/.gitconfig.local
