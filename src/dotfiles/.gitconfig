[user]
	name = Taylor Vance
	# Email intentionally unset here (work/personal split via per-repo config
	# or ~/.gitconfig.local); refuse to guess an identity instead
	useConfigOnly = true

[alias]
	# inspect
	st = status
	di = diff
	dip = diff HEAD~1
	dis = diff --staged
	l = log --graph --oneline --decorate
	ll = log --graph --pretty='%C(auto)%h%d %s %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset' --abbrev-commit
	g = grep --break --heading --line-number
	cfg = config --list

	# stage / commit
	a = add .
	c = commit
	cm = commit -m
	amend = commit --amend --no-edit

	# branch / sync
	s = switch
	f = fetch
	p = pull
	pfwl = push --force-with-lease --force-if-includes  # safe force-push (won't clobber unseen commits)
	# the remote's default branch (main/master/...)
	default = "!ref=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null) || { echo 'origin/HEAD not set; run: git remote set-head origin -a' >&2; exit 1; }; echo \"${ref#origin/}\""
	pm = "!b=$(git default) && git fetch origin \"$b:$b\""                # pull default without switching
	smp = "!b=$(git default) && git switch \"$b\" && git pull --ff-only"  # switch to default branch, ff-only pull
	fmom = "!b=$(git default) && git fetch && git merge \"origin/$b\""    # fetch, merge origin/<default>
	from = "!b=$(git default) && git fetch && git rebase \"origin/$b\""   # fetch, rebase onto origin/<default>

[branch]
	sort = -committerdate

[commit]
	verbose = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[pull]
	ff = only

[rebase]
	autostash = true
	autosquash = true

[rerere]
	# remember conflict resolutions; replay them when the same conflict reappears
	enabled = true

[diff]
	tool = nvimdiff
	colorMoved = default
	algorithm = histogram
[merge]
	tool = nvimdiff
	# include the common-ancestor version in conflict markers
	conflictStyle = zdiff3
[mergetool]
	keepBackup = false

[pager]
	diff = delta
	log = delta
	reflog = delta
	show = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	line-numbers = true
	syntax-theme = tokyonight_moon
	file-decoration-style = magenta box
	hunk-header-decoration-style = cyan box

[core]
	editor = nvim
	excludesFile = ~/.gitignore
	pager = delta

[grep]
	extendRegexp = true
	lineNumber = true

[credential]
	helper = osxkeychain

[include]
	path = ~/.gitconfig.local
