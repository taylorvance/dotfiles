[user]
	name = Taylor Vance

[alias]
	st = status
	di = diff
	a = add .
	c = commit
	s = switch
	g = grep --break --heading --line-number
	l = log --graph --oneline --decorate
	ll = log --graph --pretty='%C(auto)%h%d %s %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset' --abbrev-commit
	amend = commit --amend --no-edit

[diff]
	tool = nvimdiff
	colorMoved = default
[merge]
	tool = nvimdiff
[mergetool]
	keepBackup = false

[pager]
	diff = delta
	log = delta
	reflog = delta
	show = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	line-numbers = true
	syntax-theme = tokyonight_moon
	file-decoration-style = magenta box
	hunk-header-decoration-style = cyan box

[core]
	editor = nvim
	excludesFile = ~/.gitignore
	pager = delta

[grep]
	extendRegexp = true
	lineNumber = true

[credential]
	helper = osxkeychain

[include]
	path = ~/.gitconfig.local
